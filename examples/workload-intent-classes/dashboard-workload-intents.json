{
  "title": "Joulie Workload Intent Scheduling",
  "uid": "joulie-workload-intents",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "textbox",
        "label": "Namespace",
        "query": "joulie-intent-demo",
        "current": {
          "text": "joulie-intent-demo",
          "value": "joulie-intent-demo"
        }
      },
      {
        "name": "node",
        "type": "query",
        "label": "Node",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "query": {
          "query": "label_values(joulie_operator_node_state, node)",
          "refId": "NodeVariableQuery"
        },
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "FSM State by Node (Operator Metric)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "joulie_operator_node_state{node=~\"$node\",state=\"ActivePerformance\"}",
          "legendFormat": "{{node}} ActivePerformance"
        },
        {
          "expr": "joulie_operator_node_state{node=~\"$node\",state=\"DrainingPerformance\"}",
          "legendFormat": "{{node}} DrainingPerformance"
        },
        {
          "expr": "joulie_operator_node_state{node=~\"$node\",state=\"ActiveEco\"}",
          "legendFormat": "{{node}} ActiveEco"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "State Transitions (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(joulie_operator_state_transitions_total{node=~\"$node\",result=\"applied\"}[5m])",
          "legendFormat": "{{node}} {{from_state}}->{{to_state}} applied"
        },
        {
          "expr": "increase(joulie_operator_state_transitions_total{node=~\"$node\",result=\"deferred\"}[5m])",
          "legendFormat": "{{node}} {{from_state}}->{{to_state}} deferred"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Operator Profile vs Node Label (Side-by-side)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "joulie_operator_node_profile_label{node=~\"$node\",profile=\"performance\"}",
          "legendFormat": "{{node}} operator=performance"
        },
        {
          "expr": "joulie_operator_node_profile_label{node=~\"$node\",profile=\"eco\"}",
          "legendFormat": "{{node}} operator=eco"
        },
        {
          "expr": "joulie_operator_node_profile_label{node=~\"$node\",profile=\"draining-performance\"}",
          "legendFormat": "{{node}} operator=draining-performance"
        },
        {
          "expr": "kube_node_labels{node=~\"$node\",label_joulie_io_power_profile=\"performance\"}",
          "legendFormat": "{{node}} label=performance"
        },
        {
          "expr": "kube_node_labels{node=~\"$node\",label_joulie_io_power_profile=\"eco\"}",
          "legendFormat": "{{node}} label=eco"
        },
        {
          "expr": "kube_node_labels{node=~\"$node\",label_joulie_io_power_profile=\"draining-performance\"}",
          "legendFormat": "{{node}} label=draining-performance"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pods by Intent Class and Node",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (node) ((kube_pod_labels{namespace=\"$namespace\",label_joulie_io_workload_intent_class=\"performance\"} == 1) * on (namespace,pod) group_left(node) kube_pod_info{namespace=\"$namespace\",node=~\"$node\"})",
          "legendFormat": "{{node}} performance"
        },
        {
          "expr": "sum by (node) ((kube_pod_labels{namespace=\"$namespace\",label_joulie_io_workload_intent_class=\"eco\"} == 1) * on (namespace,pod) group_left(node) kube_pod_info{namespace=\"$namespace\",node=~\"$node\"})",
          "legendFormat": "{{node}} eco"
        },
        {
          "expr": "sum by (node) ((kube_pod_labels{namespace=\"$namespace\",label_joulie_io_workload_intent_class=\"flex\"} == 1) * on (namespace,pod) group_left(node) kube_pod_info{namespace=\"$namespace\",node=~\"$node\"})",
          "legendFormat": "{{node}} flex"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod Re-creations (5m)",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (label_joulie_io_workload_intent_class) (changes(kube_pod_status_phase{namespace=\"$namespace\",phase=\"Running\"}[5m]) * on(namespace,pod) group_left(label_joulie_io_workload_intent_class) kube_pod_labels{namespace=\"$namespace\",label_joulie_io_workload_intent_class!=\"\"})",
          "legendFormat": "{{label_joulie_io_workload_intent_class}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node Cap (W)",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "joulie_policy_cap_watts{node=~\"$node\"}",
          "legendFormat": "{{node}}"
        }
      ]
    }
  ]
}
